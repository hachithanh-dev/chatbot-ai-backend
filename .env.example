# ╔══════════════════════════════════════════════════════════════════╗
# ║  .env.example — Template for Local Development                  ║
# ║  Copy this file: cp .env.example .env                           ║
# ║  Then fill in your real values below.                           ║
# ║  ⚠️  .env is git-ignored — NEVER commit real credentials!       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Spring Profile ────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── AI API Keys ───────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
COHERE_API_KEY=your-cohere-api-key
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NVD_API_KEY=your-nvd-api-key

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=chatbot
POSTGRES_PORT=5432

DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot
DB_USERNAME=postgres
DB_PASSWORD=your-postgres-password

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ── Qdrant ────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6334

# ── Cookie ────────────────────────────────────────────────────────────
# false = HTTP localhost (dev), true = HTTPS production
APP_COOKIE_SECURE=false

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Grafana ───────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=your-grafana-password

# ── Admin ─────────────────────────────────────────────────────────────
# Comma-separated emails to seed as ADMIN role on startup
ADMIN_EMAILS=your-admin-email@gmail.com
